# URL da API (FastAPI) — padrão local: http://localhost:8098/
# VITE_API_URL=http://localhost:8098/

# --- Web3Forms — formulário "Reportar problema" (login + app logada)
# 1) https://web3forms.com — criar Access Key e definir o e-mail que recebe os relatórios
# 2) Colar a chave abaixo (sem aspas)
# 3) Reiniciar o Vite após alterar
# Documentação: frontend/docs/email-setup.md
# VITE_WEB3FORMS_ACCESS_KEY=

# --- Brevo (apenas referência — uso no BACKEND, não no Vite)
# Chave e remetente ficam no .env do servidor / Docker, nunca com prefixo VITE_.
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=noreply@seudominio.com
# BREVO_SENDER_NAME=Executiva Cloud
