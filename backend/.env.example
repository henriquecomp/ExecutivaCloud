# CORS da API (separado por vírgula). Deve incluir a origem do SPA — usada também para validar
# o cabeçalho X-Frontend-Base-URL nos links de convite e redefinição de senha.
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:3001

# SMTP Gmail (MVP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app_gmail
SMTP_FROM=seu_email@gmail.com

# E-mail que recebe report de problema do botão de suporte
SUPPORT_REPORT_TO=suporte@seudominio.com
