# URL do frontend usada nos links de convite/reset
FRONTEND_BASE_URL=http://localhost:8080

# CORS da API (separado por vírgula)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:3001

# Brevo API (preferencial: basta token + remetente)
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=noreply@seudominio.com
BREVO_SENDER_NAME=Executiva Cloud

# SMTP (opcional fallback, se não usar BREVO_API_KEY)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=seu_usuario_smtp_brevo
# SMTP_PASSWORD=sua_senha_smtp_brevo
# SMTP_FROM=noreply@seudominio.com

# E-mail que recebe report de problema do botão de suporte
SUPPORT_REPORT_TO=suporte@seudominio.com
